# Configuración de despliegue remoto para scripts/deploy-server.sh, scripts/view_logs.sh y scripts/setup-vps-user.sh
#
# IMPORTANTE:
# - Nunca commitear este archivo. Debe estar en .gitignore.
# - Nunca usar 'root'. Crear un usuario dedicado en el VPS con permisos mínimos.
# - El usuario debe tener permiso para ejecutar:
#     systemctl restart <DEPLOY_SERVICE_NAME>
#   Configurar sudoers si es necesario.

# IP o hostname del VPS (ejemplo: 203.0.113.10)
DEPLOY_SSH_HOST=

# Puerto SSH del VPS (ejemplo: 22)
DEPLOY_SSH_PORT=

# Usuario SSH en el VPS. Debe ser el mismo que ejecuta el servicio systemd.
DEPLOY_SSH_USER=

# Ruta absoluta del proyecto en el VPS (ejemplo: /var/www/datamaq)
DEPLOY_REMOTE_DIR=

# Nombre del servicio systemd (ejemplo: datamaq.service)
DEPLOY_SERVICE_NAME=
